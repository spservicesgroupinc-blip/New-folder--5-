// ─── React Hook ───────────────────────────────────────────────────────────────

export function useRealtimeInventory(userId: string) {
  const { setInventory, updateInventoryItem, setEstimates, updateEstimate } = useAppStore()

  // Delta sync down — only fetch rows newer than last sync
  const syncDown = useCallback(async (lastSyncTimestamp?: Date) => {
    const since = lastSyncTimestamp?.toISOString() ?? new Date(0).toISOString()

    const [{ data: inv }, { data: est }] = await Promise.all([
      supabase
        .from('inventory')
        .select('*')
        .eq('user_id', userId)
        .gt('last_modified', since),
      supabase
        .from('estimates')
        .select('*')
        .eq('user_id', userId)
        .gt('last_modified', since),
    ])

    if (inv?.length) setInventory(inv)
    if (est?.length) setEstimates(est)
  }, [userId, setInventory, setEstimates])

  // Complete job — calls the atomic Postgres RPC
  const completeJob = useCallback(async (estimateId: string, actuals: object) => {
    const { data, error } = await supabase.rpc('complete_job', {
      p_estimate_id: estimateId,
      p_actuals:     actuals,
      p_user_id:     userId,
    })
    if (error) throw error
    return data
  }, [userId])

  // Realtime subscription — admin dashboard receives live inventory + estimate changes
  useEffect(() => {
    const channel = supabase.channel(`rfe_company_${userId}`)

      // Inventory row updated (e.g. crew completed a job)
      .on(
        'postgres_changes',
        {
          event:  'UPDATE',
          schema: 'public',
          table:  'inventory',
          filter: `user_id=eq.${userId}`,
        },
        (payload) => {
          console.log('[Realtime] inventory update', payload.new)
          updateInventoryItem(payload.new as any)
        }
      )

      // Estimate status changed (In Progress → Completed)
      .on(
        'postgres_changes',
        {
          event:  'UPDATE',
          schema: 'public',
          table:  'estimates',
          filter: `user_id=eq.${userId}`,
        },
        (payload) => {
          const updated = payload.new as any
          console.log('[Realtime] estimate update', updated.id, updated.execution_status)
          updateEstimate(updated)
        }
      )

      .subscribe((status) => {
        console.log('[Realtime] channel status:', status)
      })

    return () => {
      supabase.removeChannel(channel)
    }
  }, [userId, updateInventoryItem, updateEstimate])

  return { syncDown, completeJob }
}